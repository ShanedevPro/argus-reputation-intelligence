# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# Argus local MVP chat model. These are optional when the BettaFish engine
# variables are already loaded in the process environment:
# QUERY_ENGINE_BASE_URL, QUERY_ENGINE_API_KEY, QUERY_ENGINE_MODEL_NAME.
ARGUS_CHAT_BASE_URL=****
ARGUS_CHAT_API_KEY=****
ARGUS_CHAT_MODEL=mimo/mimo-v2.5-pro
ARGUS_CHAT_TITLE_MODEL=mimo/mimo-v2.5-pro

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****
