# ====================== Argus Backend ======================
# Backend host, for example 0.0.0.0 or 127.0.0.1.
HOST=0.0.0.0
# Backend port. The local Flask backend defaults to 5000.
PORT=5000
# Flask session signing secret. Use a unique non-public value in shared/dev deployments.
SECRET_KEY=

# ====================== Database ======================
# Database host, for example localhost or 127.0.0.1.
DB_HOST=your_db_host
# PostgreSQL defaults to 5432; MySQL defaults to 3306.
DB_PORT=5432
# Database username.
DB_USER=your_db_user
# Database password. Do not commit real credentials.
DB_PASSWORD=your_db_password
# Database name.
DB_NAME=your_db_name
# Database charset. utf8mb4 is recommended when using MySQL-compatible storage.
DB_CHARSET=utf8mb4
# Database dialect: mysql or postgresql.
DB_DIALECT=postgresql

# ======================= LLM Providers =======================
# Each engine can use an OpenAI-compatible endpoint. Configure KEY, BASE_URL,
# and MODEL_NAME for your own provider. Never commit real API keys.

# Insight engine.
INSIGHT_ENGINE_API_KEY=
INSIGHT_ENGINE_BASE_URL=
INSIGHT_ENGINE_MODEL_NAME=

# Media engine.
MEDIA_ENGINE_API_KEY=
MEDIA_ENGINE_BASE_URL=
MEDIA_ENGINE_MODEL_NAME=

# Query engine.
QUERY_ENGINE_API_KEY=
QUERY_ENGINE_BASE_URL=
QUERY_ENGINE_MODEL_NAME=

# Report engine. Use a model with strong Chinese long-form writing ability.
REPORT_ENGINE_API_KEY=
REPORT_ENGINE_BASE_URL=
REPORT_ENGINE_MODEL_NAME=

# Optional legacy crawler agent settings. Leave blank unless you provide an external compatible crawler integration.
MINDSPIDER_API_KEY=
MINDSPIDER_BASE_URL=
MINDSPIDER_MODEL_NAME=

# Forum host engine.
FORUM_HOST_API_KEY=
FORUM_HOST_BASE_URL=
FORUM_HOST_MODEL_NAME=

# SQL keyword optimizer.
KEYWORD_OPTIMIZER_API_KEY=
KEYWORD_OPTIMIZER_BASE_URL=
KEYWORD_OPTIMIZER_MODEL_NAME=

# Optional reasoning effort passthrough for compatible model providers.
# Allowed values: minimal, low, medium, high, xhigh, none.
LLM_REASONING_EFFORT=
QUERY_ENGINE_REASONING_EFFORT=
MEDIA_ENGINE_REASONING_EFFORT=
INSIGHT_ENGINE_REASONING_EFFORT=
REPORT_ENGINE_REASONING_EFFORT=
FORUM_HOST_REASONING_EFFORT=

# ================== Web Search Providers ====================
# Tavily API key for web search.
TAVILY_API_KEY=

# Search provider type: BochaAPI, AnspireAPI, or TavilyAPI.
SEARCH_TOOL_TYPE=AnspireAPI

# Anspire AI Search API
ANSPIRE_BASE_URL=https://plugin.anspire.cn/api/ntsearch/search
ANSPIRE_API_KEY=

# Bocha AI Search API.
BOCHA_BASE_URL=https://api.bocha.cn/v1/web-search
BOCHA_WEB_SEARCH_API_KEY=

# Intake lightweight web search guardrails
INTAKE_WEB_SEARCH_DEFAULT_RESULTS=5
INTAKE_WEB_SEARCH_MAX_RESULTS=8

# Maximum seconds each backend search engine may run before the workflow
# surfaces a clear engine timeout instead of staying in a silent running state.
# Set to 0 to disable during deep diagnostics.
ARGUS_SEARCH_ENGINE_TIMEOUT_SECONDS=5400
ARGUS_SEARCH_ENGINE_CONCURRENCY=sequential
ARGUS_SEARCH_ENGINE_MAX_REFLECTIONS=1
ARGUS_SEARCH_ENGINE_MAX_PARAGRAPHS=5
ARGUS_INSIGHT_MAX_AUTO_SENTIMENT_SEARCHES=1
KEYWORD_OPTIMIZER_MAX_KEYWORDS=8

# ================== TikHub Weibo Data Prep ====================
WEIBO_DATA_PROVIDER=tikhub
TIKHUB_API_KEY=
TIKHUB_BASE_URL=
TIKHUB_TIMEOUT=10

# ================== Argus SaaS Local Demo ====================
# Optional path to a local secret env file when running a local checkout.
ARGUS_ENV_FILE=
ARGUS_FRONTEND_PORT=3010
AUTH_SECRET=
POSTGRES_URL=
# Legacy compatibility names used by the adapted frontend and demo script.
# Treat these as Argus backend URL settings.
BETTAFISH_BACKEND_URL=http://127.0.0.1:5000
NEXT_PUBLIC_BETTAFISH_BACKEND_URL=http://127.0.0.1:5000

# Optional OpenAI-compatible chat overrides. If omitted, Argus SaaS reuses
# the QUERY_ENGINE_* compatible route.
ARGUS_CHAT_BASE_URL=
ARGUS_CHAT_API_KEY=
ARGUS_CHAT_MODEL=mimo/mimo-v2.5-pro
ARGUS_CHAT_TITLE_MODEL=mimo/mimo-v2.5-pro
